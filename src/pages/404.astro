---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import { url } from '../utils/url';

const popularPages = [
  { href: '/evergreen/edu-hard-money-loans-overview', label: 'What Is Hard Money?', category: 'Financing' },
  { href: '/evergreen/edu-fix-flip-loans', label: 'Fix and Flip Loans', category: 'Financing' },
  { href: '/services/guide-real-estate-beginners', label: 'Real Estate Investing Guide', category: 'Guide' },
  { href: '/evergreen/edu-bridge-loans', label: 'Bridge Loans', category: 'Financing' },
  { href: '/evergreen/edu-private-money-lending-smb', label: 'Private Lending for SMBs', category: 'Business' },
  { href: '/evergreen/edu-real-estate-vs-stock-market', label: 'Real Estate vs Stock Market', category: 'Investing' },
];
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist. Find the capital financing information you need.">
  <Header />
  
  <main id="main-content" tabindex="-1">
    <section class="error-section">
      <div class="container">
        <div class="error-content">
          <div class="error-code">404</div>
          <h1>Page Not Found</h1>
          <p class="error-message">
            The page you're looking for doesn't exist or has been moved. 
            Don't worry—even the best deals sometimes fall through. Let's get you back on track.
          </p>
          
          <div class="error-actions">
            <Button href="/" size="lg">Go to Homepage</Button>
            <Button variant="outline" href="/contact" size="lg">Contact Us</Button>
          </div>
        </div>
        
        <div class="popular-pages">
          <h2>Popular Pages</h2>
          <p class="popular-subtitle">Looking for something specific? Try these:</p>
          
          <div class="pages-grid">
            {popularPages.map(page => (
              <a href={url(page.href)} class="page-card">
                <span class="page-category">{page.category}</span>
                <span class="page-label">{page.label}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
        
        <div class="help-section">
          <h2>Need Help?</h2>
          <p>
            If you were looking for specific information about hard money loans, private lending, 
            or alternative financing, we're here to help.
          </p>
          <div class="help-links">
            <a href={url('/evergreen/')}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
              Browse All Articles
            </a>
            <a href={url('/services/')}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
              View Guides
            </a>
            <a href={url('/contact/')}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              Contact Us
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .error-section {
    padding: 4rem 0 5rem;
    background: linear-gradient(135deg, var(--bg-primary) 0%, white 50%, var(--bg-tertiary) 100%);
    min-height: 60vh;
  }
  
  .error-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem;
  }
  
  .error-code {
    font-family: var(--font-heading);
    font-size: 8rem;
    font-weight: 700;
    color: var(--color-secondary);
    line-height: 1;
    margin-bottom: 1rem;
    opacity: 0.3;
  }
  
  @media (min-width: 768px) {
    .error-code {
      font-size: 12rem;
    }
  }
  
  .error-content h1 {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  
  @media (min-width: 768px) {
    .error-content h1 {
      font-size: 3rem;
    }
  }
  
  .error-message {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .error-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  
  .popular-pages {
    max-width: 900px;
    margin: 0 auto 4rem;
    text-align: center;
  }
  
  .popular-pages h2 {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  
  .popular-subtitle {
    font-size: 1rem;
    color: var(--text-tertiary);
    margin-bottom: 2rem;
  }
  
  .pages-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  
  @media (min-width: 768px) {
    .pages-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .pages-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .page-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: white;
    border: 2px solid var(--border-light);
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.2s ease;
    text-align: left;
  }
  
  .page-card:hover {
    border-color: var(--color-secondary);
    box-shadow: 0 4px 12px rgba(27, 54, 93, 0.1);
  }
  
  .page-category {
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-tertiary);
    background: var(--bg-tertiary);
    padding: 0.25rem 0.5rem;
    border-radius: 2px;
    white-space: nowrap;
  }
  
  .page-label {
    flex-grow: 1;
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-primary);
  }
  
  .page-card:hover .page-label {
    color: var(--color-secondary);
  }
  
  .page-card svg {
    flex-shrink: 0;
    color: var(--color-secondary);
    transition: transform 0.2s ease;
  }
  
  .page-card:hover svg {
    transform: translateX(4px);
  }
  
  .help-section {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem;
    background: white;
    border-radius: 12px;
    box-shadow: 0 4px 12px rgba(27, 54, 93, 0.08);
  }
  
  .help-section h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  
  .help-section p {
    font-size: 1rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 2rem;
  }
  
  .help-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  
  .help-links a {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--bg-tertiary);
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.9375rem;
    text-decoration: none;
    border-radius: 6px;
    transition: all 0.2s ease;
  }
  
  .help-links a:hover {
    background: var(--color-primary);
    color: white;
  }
  
  .help-links a svg {
    flex-shrink: 0;
  }
</style>
