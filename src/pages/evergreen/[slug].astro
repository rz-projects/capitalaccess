---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const evergreen = await getCollection('evergreen');
  return evergreen.map(entry => ({
    params: { slug: entry.id.replace('.md', '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, category, lastUpdated, related, image, keywords } = entry.data;

const breadcrumbItems = [
  { name: 'Educational Resources', url: '/evergreen/' },
  { name: category.charAt(0).toUpperCase() + category.slice(1), url: `/evergreen/?category=${category}` },
];
---

<ArticleLayout 
  title={title} 
  description={description} 
  category={category} 
  lastUpdated={lastUpdated}
  related={related}
  breadcrumbItems={breadcrumbItems}
>
  <Content />
</ArticleLayout>
