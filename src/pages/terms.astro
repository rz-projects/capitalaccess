---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { url } from '../utils/url';

const lastUpdated = new Date('2026-03-04');
---

<BaseLayout
  title="Terms of Service - Capital Access"
  description="Read the Terms of Service for Capital Access. By using our website and services, you agree to these terms. Important disclosures about our educational content and lender matching service."
>
  <Header />
  
  <main id="main-content" tabindex="-1">
    <article class="legal-page">
      <div class="container">
        <header class="legal-header">
          <span class="legal-badge">Legal</span>
          <h1>Terms of Service</h1>
          <p class="legal-description">Please read these Terms of Service carefully before using our website and services. By accessing or using Capital Access, you agree to be bound by these terms.</p>
          <p class="legal-meta">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
        </header>
        
        <div class="legal-content">
          <nav class="toc">
            <h2>Table of Contents</h2>
            <ul>
              <li><a href="#acceptance">Acceptance of Terms</a></li>
              <li><a href="#description">Description of Service</a></li>
              <li><a href="#user-responsibilities">User Responsibilities</a></li>
              <li><a href="#educational-disclaimer">Educational Content Disclaimer</a></li>
              <li><a href="#not-financial-advice">Not Financial Advice</a></li>
              <li><a href="#not-lender">Not a Lender Disclosure</a></li>
              <li><a href="#intellectual-property">Intellectual Property</a></li>
              <li><a href="#limitation">Limitation of Liability</a></li>
              <li><a href="#indemnification">Indemnification</a></li>
              <li><a href="#third-party">Third-Party Links</a></li>
              <li><a href="#modifications">Modifications to Terms</a></li>
              <li><a href="#termination">Termination</a></li>
              <li><a href="#governing-law">Governing Law</a></li>
              <li><a href="#contact">Contact Information</a></li>
            </ul>
          </nav>

          <section id="acceptance">
            <h2>Acceptance of Terms</h2>
            <p>By accessing or using the Capital Access website located at <a href="https://rz-projects.github.io/capitalaccess/" target="_blank" rel="noopener">https://rz-projects.github.io/capitalaccess/</a> (the "Site") and any services offered through the Site (collectively, the "Services"), you ("you," "your," or "User") agree to be bound by these Terms of Service ("Terms").</p>
            <p>If you do not agree to these Terms, you may not access or use the Site or Services.</p>
            <p>These Terms constitute a legally binding agreement between you and Capital Access ("we," "us," "our," or "Company") governing your use of the Site and Services.</p>
            <p><strong>Important:</strong> Please read these Terms carefully, especially the sections regarding disclaimers, limitations of liability, and the fact that we are NOT a direct lender and do NOT provide financial advice.</p>
          </section>

          <section id="description">
            <h2>Description of Service</h2>
            <p>Capital Access provides educational content about alternative financing options, including but not limited to hard money loans, private lending, bridge loans, and creative financing strategies. We also offer a lender matching service that connects borrowers with potential lenders in our network.</p>
            
            <h3>What We Do</h3>
            <ul>
              <li>Provide educational articles, guides, and resources about alternative financing</li>
              <li>Offer calculators and tools to help users understand financing options</li>
              <li>Connect users with lenders in our network through our consultation service</li>
              <li>Provide general information about financing terms, rates, and processes</li>
            </ul>

            <h3>What We Do NOT Do</h3>
            <ul>
              <li>Make lending decisions or extend credit</li>
              <li>Guarantee loan approval, terms, or rates</li>
              <li>Provide personalized financial, legal, or tax advice</li>
              <li>Act as a broker, lender, or financial advisor</li>
              <li>Represent or warrant the accuracy of third-party lender information</li>
            </ul>

            <h3>Eligibility</h3>
            <p>To use our Services, you must:</p>
            <ul>
              <li>Be at least 18 years of age</li>
              <li>Have the legal capacity to enter into a binding agreement</li>
              <li>Provide accurate and complete information when requested</li>
              <li>Comply with all applicable laws and regulations</li>
            </ul>
          </section>

          <section id="user-responsibilities">
            <h2>User Responsibilities</h2>
            <p>As a user of our Site and Services, you agree to:</p>
            <ul>
              <li><strong>Provide Accurate Information:</strong> When submitting inquiries or consultation requests, provide truthful, accurate, and complete information about yourself and your financing needs.</li>
              <li><strong>Maintain Confidentiality:</strong> Keep any account credentials or access information secure and confidential.</li>
              <li><strong>Use Services Lawfully:</strong> Use the Site and Services only for lawful purposes and in accordance with these Terms.</li>
              <li><strong>Respect Intellectual Property:</strong> Do not copy, reproduce, distribute, or create derivative works from our content without permission.</li>
              <li><strong>Do Not Misrepresent:</strong> Do not misrepresent your identity, affiliation, or intentions when using our Services.</li>
              <li><strong>Do Not Interfere:</strong> Do not interfere with or disrupt the operation of the Site or Services, or attempt to gain unauthorized access to any systems.</li>
              <li><strong>Conduct Due Diligence:</strong> Independently verify any information obtained through our Services before making financial decisions.</li>
            </ul>
          </section>

          <section id="educational-disclaimer">
            <h2>Educational Content Disclaimer</h2>
            <p>The content on our Site, including articles, guides, calculators, and other materials, is provided for <strong>educational and informational purposes only</strong>. This content:</p>
            <ul>
              <li>Is general in nature and may not apply to your specific situation</li>
              <li>May not reflect the most current legal, regulatory, or market conditions</li>
              <li>Should not be relied upon as the sole basis for making financial decisions</li>
              <li>May contain errors, omissions, or inaccuracies</li>
              <li>Does not constitute an offer, solicitation, or recommendation to buy, sell, or enter into any financial transaction</li>
            </ul>
            <p><strong>We make no warranties, express or implied, about the completeness, accuracy, reliability, suitability, or availability of the content on our Site.</strong></p>
            <p>Information about loan terms, rates, and conditions is provided for illustrative purposes only. Actual terms, rates, and conditions vary by lender, borrower, transaction, and market conditions.</p>
          </section>

          <section id="not-financial-advice">
            <h2>Not Financial, Legal, or Tax Advice</h2>
            <p><strong>Nothing on this Site constitutes financial, investment, legal, tax, or other professional advice.</strong></p>
            <p>The information provided through our Services is not intended to be a substitute for professional advice from qualified professionals. Before making any financial decisions, you should consult with:</p>
            <ul>
              <li>A licensed financial advisor or planner</li>
              <li>A qualified attorney</li>
              <li>A certified public accountant or tax professional</li>
              <li>A licensed mortgage broker or lender</li>
            </ul>
            <p>We do not assess your individual financial situation, risk tolerance, or investment objectives. We do not recommend specific financial products or strategies for your particular circumstances.</p>
            <p><strong>By using our Services, you acknowledge that you are solely responsible for your financial decisions and the consequences thereof.</strong></p>
          </section>

          <section id="not-lender">
            <h2>Not a Lender Disclosure</h2>
            <p><strong>Capital Access is NOT a direct lender, mortgage broker, or financial institution.</strong></p>
            <p>We do not:</p>
            <ul>
              <li>Make loans or extend credit</li>
              <li>Make lending decisions or underwrite loans</li>
              <li>Set interest rates, fees, or loan terms</li>
              <li>Service loans or collect payments</li>
              <li>Act as an agent for any lender</li>
            </ul>
            <p>Our lender matching service connects you with third-party lenders who may be able to assist with your financing needs. These lenders are independent entities with their own:</p>
            <ul>
              <li>Lending criteria and approval processes</li>
              <li>Interest rates, fees, and terms</li>
              <li>Privacy policies and practices</li>
              <li>Licenses and regulatory compliance</li>
            </ul>
            <p><strong>We do not guarantee that you will be matched with a lender, approved for a loan, or receive any specific loan terms.</strong></p>
            <p>Any loan or financing arrangement is solely between you and the lender. We are not a party to any loan agreement and have no responsibility for the performance or enforcement of any loan.</p>
          </section>

          <section id="intellectual-property">
            <h2>Intellectual Property</h2>
            <p>All content on the Site, including but not limited to text, graphics, logos, images, software, and code, is the property of Capital Access or its content suppliers and is protected by intellectual property laws.</p>
            
            <h3>Our Rights</h3>
            <p>Capital Access and its licensors retain all right, title, and interest in and to the Site and its content, including all intellectual property rights. You may not:</p>
            <ul>
              <li>Copy, reproduce, distribute, or create derivative works from our content without permission</li>
              <li>Use our trademarks, logos, or branding without authorization</li>
              <li>Remove or alter any copyright, trademark, or other proprietary notices</li>
              <li>Reverse engineer, decompile, or disassemble any software on the Site</li>
              <li>Use automated systems (bots, scrapers) to access or collect data from the Site without permission</li>
            </ul>

            <h3>Limited License</h3>
            <p>We grant you a limited, non-exclusive, non-transferable, revocable license to access and use the Site for personal, non-commercial purposes in accordance with these Terms. This license does not include the right to:</p>
            <ul>
              <li>Modify or create derivative works from the Site or its content</li>
              <li>Use the Site for commercial purposes without our consent</li>
              <li>Transfer, sublicense, or assign your access rights</li>
            </ul>

            <h3>User Content</h3>
            <p>If you submit content to us (e.g., feedback, testimonials, comments), you grant us a non-exclusive, royalty-free, perpetual, irrevocable right to use, reproduce, modify, and distribute that content in connection with our Services. You represent that you have the right to submit such content.</p>
          </section>

          <section id="limitation">
            <h2>Limitation of Liability</h2>
            <p><strong>TO THE MAXIMUM EXTENT PERMITTED BY LAW, CAPITAL ACCESS SHALL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES, INCLUDING BUT NOT LIMITED TO LOSS OF PROFITS, DATA, USE, OR OTHER INTANGIBLE LOSSES, RESULTING FROM:</strong></p>
            <ul>
              <li>Your use or inability to use the Site or Services</li>
              <li>Any content, information, or services obtained through the Site</li>
              <li>Unauthorized access to or alteration of your data</li>
              <li>Any third-party conduct or content</li>
              <li>Any loan or financing arrangement with a third-party lender</li>
              <li>Any decision made based on information from our Site</li>
            </ul>
            <p><strong>IN NO EVENT SHALL OUR TOTAL LIABILITY TO YOU FOR ALL CLAIMS EXCEED THE AMOUNT YOU PAID TO US, IF ANY, FOR ACCESSING THE SITE OR SERVICES.</strong></p>
            <p>Some jurisdictions do not allow the exclusion of certain warranties or the limitation of liability for consequential damages, so the above limitations may not apply to you.</p>
            
            <h3>Assumption of Risk</h3>
            <p>You acknowledge and agree that:</p>
            <ul>
              <li>Use of our Site and Services is at your own risk</li>
              <li>Financial decisions involve risk, and you are solely responsible for your decisions</li>
              <li>We do not guarantee the accuracy, completeness, or timeliness of information on the Site</li>
              <li>Third-party lenders are responsible for their own products and services</li>
            </ul>
          </section>

          <section id="indemnification">
            <h2>Indemnification</h2>
            <p>You agree to indemnify, defend, and hold harmless Capital Access and its officers, directors, employees, agents, and affiliates from and against any claims, damages, losses, liabilities, and expenses (including reasonable attorneys' fees) arising out of or related to:</p>
            <ul>
              <li>Your use of the Site or Services</li>
              <li>Your violation of these Terms</li>
              <li>Your violation of any rights of another party</li>
              <li>Your submission of content to the Site</li>
              <li>Your conduct in connection with any lender or third party</li>
            </ul>
            <p>This indemnification obligation survives termination of these Terms and your use of the Site.</p>
          </section>

          <section id="third-party">
            <h2>Third-Party Links and Services</h2>
            <p>Our Site may contain links to third-party websites, including lender websites and other resources. We are not responsible for:</p>
            <ul>
              <li>The content, accuracy, or practices of third-party sites</li>
              <li>The products or services offered by third parties</li>
              <li>The privacy policies of third parties</li>
              <li>Any transactions or agreements you enter into with third parties</li>
            </ul>
            <p>When you click on a third-party link, you leave our Site and are subject to the terms and policies of that third party. We encourage you to review the terms and privacy policies of any third-party sites you visit.</p>
            <p><strong>We do not endorse or guarantee the products, services, or reliability of any third-party linked from our Site.</strong></p>
          </section>

          <section id="modifications">
            <h2>Modifications to Terms</h2>
            <p>We reserve the right to modify these Terms at any time. When we make material changes, we will:</p>
            <ul>
              <li>Update the "Last Updated" date at the top of this page</li>
              <li>Post the modified Terms on our Site</li>
              <li>Provide notice of significant changes through our Site or by email</li>
            </ul>
            <p>Your continued use of the Site or Services after any changes constitutes your acceptance of the modified Terms. If you do not agree to the modified Terms, you must stop using the Site and Services.</p>
            <p>We encourage you to review these Terms periodically.</p>
          </section>

          <section id="termination">
            <h2>Termination</h2>
            <p>We may terminate or suspend your access to the Site and Services at any time, without notice, for any reason, including but not limited to:</p>
            <ul>
              <li>Violation of these Terms</li>
              <li>Conduct that we believe is harmful to other users or to our business</li>
              <li>Legal or regulatory requirements</li>
              <li>Discontinuation of the Site or Services</li>
            </ul>
            <p>Upon termination:</p>
            <ul>
              <li>Your right to use the Site and Services will immediately cease</li>
              <li>We may delete your account and any associated data</li>
              <li>Provisions of these Terms that by their nature should survive termination will remain in effect</li>
            </ul>
            <p>You may stop using the Site and Services at any time.</p>
          </section>

          <section id="governing-law">
            <h2>Governing Law and Dispute Resolution</h2>
            <p>These Terms shall be governed by and construed in accordance with the laws of the State of New York, without regard to its conflict of law provisions.</p>
            <p>Any dispute arising out of or relating to these Terms or your use of the Site or Services shall be resolved through binding arbitration in New York, New York, in accordance with the rules of the American Arbitration Association.</p>
            <p>You waive any right to participate in class action lawsuits or class-wide arbitration.</p>
            <p>If any provision of these Terms is found to be unenforceable, the remaining provisions will continue in full force and effect.</p>
          </section>

          <section id="contact">
            <h2>Contact Information</h2>
            <p>If you have questions about these Terms, please contact us:</p>
            <div class="contact-box">
              <p><strong>Capital Access</strong></p>
              <p>123 Finance Street, Suite 100<br>New York, NY 10001</p>
              <p>Email: <a href="mailto:legal@capitalaccess.com">legal@capitalaccess.com</a></p>
              <p>Phone: (555) 123-4567</p>
            </div>
          </section>

          <section class="agreement-notice">
            <h2>Acknowledgment</h2>
            <p>By using our Site and Services, you acknowledge that you have read, understood, and agree to be bound by these Terms of Service, including the disclaimers and limitations of liability set forth herein.</p>
            <p><strong>YOU ACKNOWLEDGE THAT YOU HAVE READ AND UNDERSTOOD THESE TERMS, INCLUDING THAT:</strong></p>
            <ul>
              <li>Capital Access is NOT a direct lender</li>
              <li>Content is for educational purposes only and is NOT financial advice</li>
              <li>You are solely responsible for your financial decisions</li>
              <li>Our liability is limited as described above</li>
            </ul>
          </section>
        </div>
      </div>
    </article>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .legal-page {
    padding: 3rem 0 5rem;
    background: #FFFFFF;
  }

  .legal-header {
    max-width: 800px;
    margin: 0 auto 3rem;
    text-align: center;
    padding-top: 2rem;
  }

  .legal-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-secondary);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    margin-bottom: 1rem;
  }

  .legal-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .legal-header h1 {
      font-size: 3rem;
    }
  }

  .legal-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .legal-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 0;
  }

  .legal-meta svg {
    color: var(--text-muted);
  }

  .legal-content {
    max-width: 800px;
    margin: 0 auto;
  }

  .toc {
    background: var(--bg-tertiary);
    border-radius: 8px;
    padding: 1.5rem 2rem;
    margin-bottom: 3rem;
  }

  .toc h2 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .toc ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }

  @media (min-width: 640px) {
    .toc ul {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .toc a {
    color: var(--text-primary);
    font-size: 0.9375rem;
    text-decoration: none;
    display: block;
    padding: 0.25rem 0;
  }

  .toc a:hover {
    color: var(--color-secondary);
  }

  .legal-content section {
    margin-bottom: 2.5rem;
  }

  .legal-content h2 {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
  }

  .legal-content h2:first-of-type {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }

  .legal-content h3 {
    font-size: 1.25rem;
    color: var(--color-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .legal-content p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }

  .legal-content ul,
  .legal-content ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .legal-content li {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .legal-content a {
    color: var(--color-secondary);
    text-decoration: underline;
  }

  .legal-content a:hover {
    color: var(--color-secondary-dark);
  }

  .legal-content strong {
    font-weight: 600;
    color: var(--color-primary);
  }

  .contact-box {
    background: var(--bg-tertiary);
    border-radius: 8px;
    padding: 1.5rem;
    margin-top: 1rem;
  }

  .contact-box p {
    margin-bottom: 0.5rem;
  }

  .contact-box p:last-child {
    margin-bottom: 0;
  }

  .agreement-notice {
    background: var(--color-primary);
    color: white;
    border-radius: 8px;
    padding: 2rem;
    margin-top: 3rem;
  }

  .agreement-notice h2 {
    color: white;
    border-top: none;
    margin-top: 0;
    padding-top: 0;
  }

  .agreement-notice p {
    color: rgba(255, 255, 255, 0.9);
  }

  .agreement-notice ul {
    color: rgba(255, 255, 255, 0.9);
  }

  .agreement-notice li {
    color: rgba(255, 255, 255, 0.9);
  }

  .agreement-notice strong {
    color: var(--color-secondary);
  }
</style>
