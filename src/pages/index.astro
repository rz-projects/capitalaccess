---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import Card from '../components/Card.astro';

const heroTitle = 'Capital for Those Who Move Fast';
const heroDescription = 'Hard money loans. Private lending. Creative financing. When traditional banks can\'t move fast enough, we show you who can—and how to make it work for your next deal.';

const trustIndicators = [
  { value: '15+', label: 'Years of Industry Expertise' },
  { value: '500+', label: 'Educational Articles' },
  { value: 'Expert-Vetted', label: 'Content' },
  { value: 'Direct', label: 'Lender Connections' },
];

const services = [
  {
    title: 'Hard Money Loans',
    description: 'Fast, asset-based financing for real estate investors. Close in days, not months. Based on property value, not your credit score.',
    features: 'Fix & flip • Bridge financing • Rental properties • 10-14 day closings',
    href: '/services/hard-money-loans',
    icon: 'key',
  },
  {
    title: 'Private Money Lending',
    description: 'Direct access to private capital for real estate and business investments. Flexible terms, relationship-based lending, creative deal structures.',
    features: 'Business investment • Real estate • Flexible terms • Direct relationships',
    href: '/services/private-lending',
    icon: 'handshake',
  },
  {
    title: 'Business & Working Capital',
    description: 'Funding solutions for entrepreneurs and small business owners. Acquisition financing, working capital, and growth funding when banks say no.',
    features: 'Business acquisition • Working capital • Expansion funding • Quick approval',
    href: '/services/business-capital',
    icon: 'building',
  },
];

const whyChooseUs = [
  { title: 'Expert-Vetted Content', description: 'Every article reviewed by financial professionals. Real expertise, not just opinions.', icon: 'badge' },
  { title: 'Action-Oriented Guidance', description: 'Step-by-step processes, checklists, and calculators. Not just information—direction.', icon: 'compass' },
  { title: 'Lender Connections', description: 'Access to our network of vetted hard money and private lenders. Real funding sources, not just leads.', icon: 'link' },
  { title: 'Transparent & Honest', description: 'We tell you the real costs, real risks, and real timelines. No sugarcoating, no hidden agendas.', icon: 'shield' },
];

const teamMembers = [
  { name: 'Michael Torres', title: 'Founder & Principal', credentials: '20+ years in real estate investment', years: 'Former hard money lender' },
  { name: 'Jennifer Walsh', title: 'Director of Education', credentials: 'CFA, former investment banker', years: 'Translates complex financing' },
  { name: 'David Chen', title: 'Lending Relations Director', credentials: '15+ years in private lending', years: 'Connects borrowers to lenders' },
  { name: 'Sarah Mitchell', title: 'Content & Research Lead', credentials: 'Financial journalist, MBA', years: 'Researches every article' },
];

const resources = [
  { title: 'Hard Money Calculator', description: 'Estimate your total costs, monthly payments, and ROI for hard money financing.', cta: 'Use Calculator', icon: 'calculator' },
  { title: 'Fix & Flip Financing Guide', description: 'Complete guide to funding your first (or next) fix-and-flip project from purchase to sale.', cta: 'Download Free Guide', icon: 'book' },
  { title: 'Lender Comparison Checklist', description: '15-point checklist to evaluate and compare hard money and private lenders.', cta: 'Get Checklist', icon: 'checklist' },
];
---

<BaseLayout
  title="Capital Access - Alternative Financing for Real Estate Investors"
  description="Expert-vetted education on hard money loans, private lending, and creative financing. Get matched with the right funding for your next deal. Free consultation."
>
  <Header />
  
  <main id="main-content" tabindex="-1">
    <section class="hero">
      <div class="container">
        <div class="hero-content">
          <span class="hero-badge">Trusted by 10,000+ Investors & Entrepreneurs</span>
          <h1>{heroTitle}</h1>
          <p class="hero-description">{heroDescription}</p>
          <div class="hero-actions">
            <Button href="/contact" size="lg">Find Your Funding Match</Button>
            <Button variant="outline" href="/services" size="lg">Explore Financing Options</Button>
          </div>
          <div class="hero-trust">
            {trustIndicators.map(indicator => (
              <div class="trust-item">
                <span class="trust-value">{indicator.value}</span>
                <span class="trust-label">{indicator.label}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
    
    <section class="trust-bar">
      <div class="container">
        <p class="trust-bar-label">As Featured In</p>
        <div class="logo-strip">
          <span class="logo-placeholder">Forbes</span>
          <span class="logo-placeholder">Bloomberg</span>
          <span class="logo-placeholder">CNBC</span>
          <span class="logo-placeholder">Yahoo Finance</span>
          <span class="logo-placeholder">Business Insider</span>
          <span class="logo-placeholder">NerdWallet</span>
        </div>
      </div>
    </section>
    
    <section class="services section">
      <div class="container">
        <div class="section-header">
          <h2>Alternative Financing Solutions</h2>
          <p>Not every deal fits in a bank's box. Here's how to fund yours.</p>
        </div>
        <div class="services-grid">
          {services.map(service => (
            <Card
              title={service.title}
              description={service.description}
              features={service.features}
              href={service.href}
              icon={service.icon}
            />
          ))}
        </div>
      </div>
    </section>
    
    <section class="why-choose section">
      <div class="container">
        <div class="section-header">
          <h2>Why Capital Access</h2>
          <p>Knowledge that moves you from "interested" to "funded"</p>
        </div>
        <div class="why-grid">
          {whyChooseUs.map(item => (
            <div class="why-item">
              <div class="why-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  {item.icon === 'badge' && <><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></>}
                  {item.icon === 'compass' && <><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></>}
                  {item.icon === 'link' && <><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></>}
                  {item.icon === 'shield' && <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></>}
                </svg>
              </div>
              <h3 class="why-title">{item.title}</h3>
              <p class="why-description">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <section class="team section">
      <div class="container">
        <div class="section-header">
          <h2>Meet Our Experts</h2>
          <p>Financial professionals who've been in your shoes</p>
        </div>
        <div class="team-grid">
          {teamMembers.map(member => (
            <div class="team-card">
              <div class="team-image" role="img" aria-label={`Photo of ${member.name}`}></div>
              <div class="team-info">
                <h3 class="team-name">{member.name}</h3>
                <p class="team-title">{member.title}</p>
                <span class="team-credentials">{member.credentials}</span>
                <p class="team-years">{member.years}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="team-cta">
          <Button variant="outline-gold" href="/about">Meet the Full Team</Button>
        </div>
      </div>
    </section>
    
    <section class="resources section section-light">
      <div class="container">
        <div class="section-header">
          <h2>Tools & Resources</h2>
          <p>Calculate, compare, and plan with confidence</p>
        </div>
        <div class="resources-grid">
          {resources.map(resource => (
            <div class="resource-card">
              <div class="resource-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  {resource.icon === 'calculator' && <><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/></>}
                  {resource.icon === 'book' && <><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></>}
                  {resource.icon === 'checklist' && <><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></>}
                </svg>
              </div>
              <h3 class="resource-title">{resource.title}</h3>
              <p class="resource-description">{resource.description}</p>
              <Button variant="primary" size="sm">{resource.cta}</Button>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <section class="testimonials section">
      <div class="container">
        <div class="section-header">
          <h2>What Our Readers Say</h2>
          <p>Real stories from real investors</p>
        </div>
        <div class="testimonial-featured">
          <span class="testimonial-quote-mark">"</span>
          <p class="testimonial-quote">Capital Access helped me understand hard money loans when I didn't even know they existed. Their guides walked me through every step, and I closed on my first investment property in 12 days. The traditional lender I started with was still 'reviewing my application.'</p>
          <div class="testimonial-author">
            <div class="testimonial-avatar" role="img" aria-label="Photo of Marcus R."></div>
            <div class="testimonial-author-info">
              <p class="testimonial-name">Marcus R.</p>
              <p class="testimonial-meta">Phoenix, AZ • First-time real estate investor</p>
            </div>
          </div>
          <div class="testimonial-rating">
            <span>★★★★★</span>
          </div>
        </div>
      </div>
    </section>
    
    <section class="final-cta section">
      <div class="container">
        <div class="cta-content">
          <h2>Ready to Find Your Funding?</h2>
          <p>Get matched with the right financing for your next deal. Free consultation, no obligation.</p>
          <div class="cta-actions">
            <Button variant="secondary" size="lg">Get Your Free Consultation</Button>
            <Button variant="outline-gold" size="lg">Call (555) 123-4567</Button>
          </div>
          <p class="cta-note">No obligation. 100% confidential. Expert guidance, not sales pressure.</p>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .section {
    padding: 4rem 0;
  }
  
  @media (min-width: 768px) {
    .section {
      padding: 5rem 0;
    }
  }
  
  .section-light {
    background: var(--bg-tertiary);
  }
  
  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3rem;
    padding-top: 1rem;
  }
  
  .section-header::before {
    content: '';
    display: block;
    width: 48px;
    height: 3px;
    background: var(--color-secondary);
    margin: 0 auto 1.5rem;
    border-radius: 2px;
  }
  
  .section-header h2 {
    margin-bottom: 0.75rem;
    color: #1B365D;
    font-weight: 700;
  }
  
  .section-header p {
    color: #1A1A1A;
    font-size: 1.25rem;
    line-height: 1.6;
    font-weight: 500;
  }
  
  .hero {
    padding: 5rem 0 4rem;
    background: linear-gradient(135deg, var(--bg-primary) 0%, white 50%, var(--bg-tertiary) 100%);
    position: relative;
  }
  
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(27, 54, 93, 0.03) 1px, transparent 1px);
    background-size: 24px 24px;
    pointer-events: none;
  }
  
  @media (min-width: 768px) {
    .hero {
      padding: 7.5rem 0 5rem;
    }
  }
  
  .hero-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    position: relative;
  }
  
  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }
  
  .hero h1 {
    margin-bottom: 1.5rem;
  }
  
  .hero-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    margin-bottom: 2rem;
    line-height: 1.6;
  }
  
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 3rem;
  }
  
  .hero-trust {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
  }
  
  @media (min-width: 768px) {
    .hero-trust {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .trust-item {
    text-align: center;
  }
  
  .trust-value {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-secondary-text);
    margin-bottom: 0.25rem;
  }
  
  .trust-label {
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }
  
  .trust-bar {
    padding: 2.5rem 0;
    background: var(--bg-tertiary);
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }
  
  .trust-bar-label {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  
  .logo-strip {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem;
  }
  
  .logo-placeholder {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--text-muted);
    opacity: 0.4;
    transition: opacity 0.2s ease;
  }
  
  .logo-placeholder:hover {
    opacity: 0.8;
  }
  
  .services {
    background: #FFFFFF;
  }
  
  .services .section-header h2 {
    color: #1B365D;
  }
  
  .services .section-header p {
    color: #2C2C2C;
  }
  
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .why-choose {
    background: var(--color-primary);
    color: white;
  }
  
  .why-choose .section-header::before {
    background: var(--color-secondary);
  }
  
  .why-choose .section-header h2 {
    color: white;
    font-weight: 700;
  }
  
  .why-choose .section-header p {
    color: #FFFFFF;
    font-size: 1.25rem;
  }
  
  .why-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  
  @media (min-width: 768px) {
    .why-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .why-item {
    text-align: center;
  }
  
  .why-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    border: 2px solid var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    background: transparent;
  }
  
  .why-icon svg {
    width: 24px;
    height: 24px;
    color: white;
  }
  
  .why-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-secondary);
    margin-bottom: 0.5rem;
  }
  
  .why-description {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }
  
  .team {
    background: #FAF8F5;
  }
  
  .team .section-header h2 {
    color: #1B365D;
  }
  
  .team .section-header p {
    color: #2C2C2C;
  }
  
  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }
  
  @media (min-width: 768px) {
    .team-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .team-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(27, 54, 93, 0.08);
    transition: all 0.3s ease;
  }
  
  .team-card:hover {
    box-shadow: 0 8px 24px rgba(27, 54, 93, 0.12);
    transform: translateY(-4px);
  }
  
  .team-image {
    aspect-ratio: 1;
    background: linear-gradient(135deg, var(--bg-tertiary) 0%, var(--border-light) 100%);
    filter: grayscale(100%);
    transition: filter 0.3s ease;
  }
  
  .team-card:hover .team-image {
    filter: grayscale(0%);
  }
  
  .team-info {
    padding: 1.5rem;
    text-align: center;
  }
  
  .team-name {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }
  
  .team-title {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }
  
  .team-credentials {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    background: var(--color-secondary);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 2px;
    margin-bottom: 0.5rem;
  }
  
  .team-years {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    margin: 0;
  }
  
  .team-cta {
    text-align: center;
  }
  
  .resources-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  @media (min-width: 768px) {
    .resources-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  .resource-card {
    background: var(--bg-primary);
    border: 2px solid var(--border-light);
    border-radius: 8px;
    padding: 2rem;
    text-align: center;
    transition: border-color 0.2s ease;
  }
  
  .resource-card:hover {
    border-color: var(--color-secondary);
  }
  
  .resource-icon {
    width: 48px;
    height: 48px;
    margin: 0 auto 1rem;
    color: var(--color-primary);
  }
  
  .resource-icon svg {
    width: 100%;
    height: 100%;
  }
  
  .resource-title {
    font-size: 1.125rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }
  
  .resource-description {
    font-size: 0.875rem;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
  }
  
  .testimonials {
    background: #FFFFFF;
  }
  
  .testimonials .section-header h2 {
    color: #1B365D;
  }
  
  .testimonials .section-header p {
    color: #2C2C2C;
  }
  
  .testimonial-featured {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
    padding: 3rem;
    background: white;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(27, 54, 93, 0.1);
  }
  
  .testimonial-quote-mark {
    font-family: var(--font-heading);
    font-size: 4rem;
    color: var(--color-secondary);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }
  
  .testimonial-quote {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-style: italic;
    color: var(--color-primary);
    line-height: 1.5;
    margin-bottom: 2rem;
  }
  
  .testimonial-author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  
  .testimonial-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--bg-tertiary) 0%, var(--border-light) 100%);
  }
  
  .testimonial-author-info {
    text-align: left;
  }
  
  .testimonial-name {
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }
  
  .testimonial-meta {
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 0;
  }
  
  .testimonial-rating {
    margin-top: 1rem;
    color: var(--color-secondary);
    font-size: 1.25rem;
    letter-spacing: 0.25rem;
  }
  
  .final-cta {
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    color: white;
    padding-bottom: 5rem;
  }
  
  .cta-content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  
  .final-cta h2 {
    color: white;
    margin-bottom: 1rem;
  }
  
  .final-cta p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }
  
  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  
  .cta-note {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }
</style>
