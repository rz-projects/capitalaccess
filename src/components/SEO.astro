---
import { url } from '../utils/url';

interface Props {
  title: string;
  description: string;
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  author?: string;
  section?: string;
  noindex?: boolean;
  canonicalUrl?: string;
}

const {
  title,
  description,
  type = 'website',
  image = '/og-default.svg',
  publishedTime,
  modifiedTime,
  author,
  section,
  noindex = false,
  canonicalUrl,
} = Astro.props;

const siteUrl = 'https://rz-projects.github.io/capitalaccess';
const fullTitle = title.includes('Capital Access') ? title : `${title} | Capital Access`;
const canonical = canonicalUrl || Astro.url.href;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;
---

<!-- Primary Meta Tags -->
<meta name="title" content={fullTitle} />
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Capital Access" />
<meta property="og:locale" content="en_US" />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
{author && <meta property="article:author" content={author} />}
{section && <meta property="article:section" content={section} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Additional SEO Meta Tags -->
<meta name="author" content={author || "Capital Access"} />
<meta name="language" content="English" />
<meta name="revisit-after" content="7 days" />
<meta name="generator" content={Astro.generator} />

<!-- JSON-LD Structured Data -->
{type === 'website' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Capital Access",
    "url": siteUrl,
    "description": "Your trusted partner for alternative financing education. Expert-vetted content on hard money loans, private lending, and creative financing.",
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": `${siteUrl}/evergreen/?search={search_term_string}`
      },
      "query-input": "required name=search_term_string"
    },
    "publisher": {
      "@type": "Organization",
      "name": "Capital Access",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/logo.svg`,
        "width": 200,
        "height": 60
      }
    }
  })} />
)}

{type === 'article' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": ogImage,
    "datePublished": publishedTime?.toISOString(),
    "dateModified": (modifiedTime || publishedTime)?.toISOString(),
    "author": {
      "@type": "Organization",
      "name": "Capital Access",
      "url": siteUrl
    },
    "publisher": {
      "@type": "Organization",
      "name": "Capital Access",
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/logo.svg`,
        "width": 200,
        "height": 60
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": canonical
    }
  })} />
)}
