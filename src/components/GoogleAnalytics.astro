---
/**
 * Google Analytics 4 Component
 * 
 * This component adds the GA4 tracking script to the page.
 * It uses the Measurement ID from environment variables.
 * 
 * Features:
 * - Respects do-not-track signals
 * - Supports cookie consent mode
 * - Enables enhanced measurement features
 * - Tracks page views automatically
 */

const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const enableAnalytics = import.meta.env.PUBLIC_ENABLE_ANALYTICS === 'true';
const requireConsent = import.meta.env.PUBLIC_REQUIRE_CONSENT === 'true';

// Don't render if no measurement ID or analytics disabled
if (!measurementId || !enableAnalytics) {
  return;
}
---

<!-- Google tag (gtag.js) -->
<script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`} async></script>
<script is:inline>
  // Check for Do Not Track
  const dnt = navigator.doNotTrack || window.doNotTrack || navigator.msDoNotTrack;
  const dntEnabled = dnt === '1' || dnt === 'yes';
  
  // Check for consent if required
  const consentRequired = ${requireConsent};
  const hasConsent = !consentRequired || localStorage.getItem('analytics_consent') === 'true';
  
  // Initialize dataLayer
  window.dataLayer = window.dataLayer || [];
  
  function gtag(){dataLayer.push(arguments);}
  
  // Configure GA4 with consent mode if required
  if (consentRequired) {
    gtag('consent', 'default', {
      'analytics_storage': hasConsent ? 'granted' : 'denied',
      'ad_storage': 'denied',
      'wait_for_update': 500
    });
  }
  
  // Only initialize if DNT not enabled and has consent
  if (!dntEnabled && hasConsent) {
    gtag('js', new Date());
    gtag('config', '${measurementId}', {
      'page_title': document.title,
      'page_location': window.location.href,
      'send_page_view': true,
      'cookie_flags': 'SameSite=None;Secure',
      'custom_map': {
        'dimension1': 'content_type',
        'dimension2': 'article_category',
        'dimension3': 'user_type'
      }
    });
  }
  
  // Store gtag function globally for custom events
  window.trackEvent = function(eventName, eventParams = {}) {
    if (!dntEnabled && hasConsent && typeof gtag === 'function') {
      gtag('event', eventName, eventParams);
    }
  };
  
  // Helper to update consent
  window.updateAnalyticsConsent = function(granted) {
    if (typeof gtag === 'function') {
      gtag('consent', 'update', {
        'analytics_storage': granted ? 'granted' : 'denied'
      });
    }
    localStorage.setItem('analytics_consent', granted.toString());
  };
</script>
