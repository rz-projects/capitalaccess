---
import { url } from '../utils/url';

const navItems = [
  { href: '/', label: 'Home' },
  {
    label: 'Financing',
    children: [
      { href: '/evergreen/edu-hard-money-loans-overview', label: 'What Is Hard Money?' },
      { href: '/evergreen/edu-hard-money-lenders', label: 'Hard Money Lenders' },
      { href: '/evergreen/edu-how-to-get-hard-money-loan', label: 'How to Get a Hard Money Loan' },
      { href: '/evergreen/edu-hard-money-loan-uses', label: 'Hard Money Loan Uses' },
      { href: '/evergreen/edu-hard-money-vs-private-lending', label: 'Hard Money vs Private Lending' },
      { href: '/evergreen/edu-fix-flip-loans', label: 'Fix and Flip Loans' },
      { href: '/evergreen/edu-bridge-loans', label: 'Bridge Loans' },
      { href: '/evergreen/edu-commercial-bridge-loan', label: 'Commercial Bridge Loans' },
      { href: '/evergreen/edu-cash-out-refinance', label: 'Cash Out Refinance' },
      { href: '/evergreen/edu-subprime-lending', label: 'Subprime Lending' },
    ]
  },
  {
    label: 'Investing',
    children: [
      { href: '/evergreen/edu-real-estate-vs-stock-market', label: 'Real Estate vs Stock Market' },
    ]
  },
  {
    label: 'Business',
    children: [
      { href: '/evergreen/edu-private-money-lending-smb', label: 'Private Lending for SMBs' },
      { href: '/evergreen/edu-starting-small-business', label: 'Starting a Business' },
      { href: '/evergreen/edu-buying-small-business', label: 'Buying a Business' },
    ]
  },
  {
    label: 'Guides',
    children: [
      { href: '/services/guide-real-estate-beginners', label: 'Real Estate Investing Guide' },
    ]
  },
  { href: '/contact', label: 'Contact' },
];
---

<header class="header">
  <a href={url('#main-content')} class="skip-link">Skip to main content</a>
  <nav class="nav container">
    <a href={url('/')} class="logo">
      <span class="logo-text">Capital Access</span>
    </a>
    
    <button class="mobile-menu-toggle" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger"></span>
    </button>
    
    <ul class="nav-links">
      {navItems.map(item => (
        <li class={item.children ? 'has-dropdown' : ''}>
          {item.children ? (
            <>
              <button class="nav-link dropdown-trigger" aria-expanded="false">
                {item.label}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"/>
                </svg>
              </button>
              <ul class="dropdown-menu">
                {item.children.map(child => (
                  <li>
                    <a href={url(child.href)}>{child.label}</a>
                  </li>
                ))}
              </ul>
            </>
          ) : (
            <a href={url(item.href)} class="nav-link">{item.label}</a>
          )}
        </li>
      ))}
    </ul>
  </nav>
</header>

<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    padding: 0.75rem 1.5rem;
    border-radius: 0 0 4px 4px;
    text-decoration: none;
    font-weight: 600;
    z-index: 9999;
    transition: top 0.2s ease;
  }
  
  .skip-link:focus {
    top: 0;
    outline: 2px solid var(--color-secondary);
    outline-offset: 2px;
  }
  
  .header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background: var(--color-primary);
    border-bottom: 3px solid var(--color-secondary);
    box-shadow: var(--shadow-md);
  }
  
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
  }
  
  .logo {
    display: flex;
    align-items: center;
    gap: var(--spacing-3);
  }
  
  .logo-text {
    font-family: var(--font-heading);
    font-size: var(--font-size-2xl);
    font-weight: var(--font-weight-bold);
    color: white;
  }
  
  .nav-links {
    display: none;
    list-style: none;
    gap: var(--spacing-6);
  }
  
  @media (min-width: 768px) {
    .nav-links {
      display: flex;
    }
  }
  
  .nav-links > li {
    position: relative;
  }
  
  .nav-link {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-medium);
    color: white;
    padding: var(--spacing-2) 0;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-family: inherit;
  }
  
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-secondary);
    transition: width var(--transition-normal);
  }
  
  .nav-link:hover {
    color: var(--color-secondary);
  }
  
  .nav-link:hover::after {
    width: 100%;
  }
  
  .dropdown-trigger svg {
    transition: transform 0.2s ease;
  }
  
  .has-dropdown:hover .dropdown-trigger svg,
  .dropdown-trigger[aria-expanded="true"] svg {
    transform: rotate(180deg);
  }
  
  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    background: white;
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(27, 54, 93, 0.15);
    min-width: 280px;
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: all 0.2s ease;
    list-style: none;
    z-index: 100;
  }
  
  .has-dropdown:hover .dropdown-menu,
  .dropdown-menu.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  
  .dropdown-menu li {
    margin: 0;
  }
  
  .dropdown-menu a {
    display: block;
    padding: 0.75rem 1.25rem;
    color: var(--color-primary);
    font-size: 0.9375rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  
  .dropdown-menu a:hover {
    background: var(--bg-tertiary);
    color: var(--color-secondary);
    padding-left: 1.5rem;
  }
  
  .mobile-menu-toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    padding: var(--spacing-2);
  }
  
  @media (min-width: 768px) {
    .mobile-menu-toggle {
      display: none;
    }
  }
  
  .hamburger {
    position: relative;
    width: 24px;
    height: 2px;
    background: white;
    transition: background var(--transition-fast);
  }
  
  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 24px;
    height: 2px;
    background: white;
    transition: transform var(--transition-fast);
  }
  
  .hamburger::before {
    top: -8px;
  }
  
  .hamburger::after {
    bottom: -8px;
  }
  
  .nav-links.is-open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 80px;
    left: 0;
    right: 0;
    background: var(--color-primary);
    padding: var(--spacing-6);
    gap: 0;
    box-shadow: var(--shadow-lg);
    max-height: 70vh;
    overflow-y: auto;
  }
  
  .nav-links.is-open > li {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .nav-links.is-open > li:last-child {
    border-bottom: none;
  }
  
  .nav-links.is-open .nav-link {
    font-size: var(--font-size-lg);
    padding: var(--spacing-4) 0;
    width: 100%;
    justify-content: space-between;
  }
  
  .nav-links.is-open .dropdown-menu {
    position: static;
    opacity: 1;
    visibility: visible;
    transform: none;
    box-shadow: none;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 0;
    padding: 0;
    display: none;
  }
  
  .nav-links.is-open .dropdown-menu.is-open {
    display: block;
  }
  
  .nav-links.is-open .dropdown-menu a {
    color: rgba(255, 255, 255, 0.9);
    padding: var(--spacing-3) var(--spacing-6);
    font-size: var(--font-size-base);
  }
  
  .nav-links.is-open .dropdown-menu a:hover {
    background: rgba(255, 255, 255, 0.1);
    color: var(--color-secondary);
    padding-left: var(--spacing-8);
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-menu-toggle');
  const navLinks = document.querySelector('.nav-links');
  const dropdownTriggers = document.querySelectorAll('.dropdown-trigger');
  
  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', (!isExpanded).toString());
    navLinks?.classList.toggle('is-open');
  });
  
  dropdownTriggers.forEach(trigger => {
    trigger.addEventListener('click', (e) => {
      const isMobile = window.innerWidth < 768;
      if (isMobile) {
        e.preventDefault();
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', (!isExpanded).toString());
        const dropdown = trigger.nextElementSibling;
        dropdown?.classList.toggle('is-open');
      }
    });
  });
  
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.has-dropdown')) {
      dropdownTriggers.forEach(trigger => {
        trigger.setAttribute('aria-expanded', 'false');
      });
    }
  });
</script>
