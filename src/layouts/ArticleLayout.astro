---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';
import BreadcrumbSchema from '../components/BreadcrumbSchema.astro';
import { url } from '../utils/url';

interface Props {
  title: string;
  description: string;
  category?: string;
  lastUpdated?: Date;
  related?: string[];
  breadcrumbItems?: { name: string; url: string }[];
}

const { title, description, category, lastUpdated, related, breadcrumbItems } = Astro.props;

const defaultBreadcrumbs = category
  ? [{ name: category.charAt(0).toUpperCase() + category.slice(1), url: '/evergreen/' }]
  : [];
const breadcrumbs = breadcrumbItems || defaultBreadcrumbs;
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  modifiedTime={lastUpdated}
  section={category}
>
  <Header />
  {breadcrumbs.length > 0 && <BreadcrumbSchema items={breadcrumbs} />}
  
  <main id="main-content" tabindex="-1">
    <article class="article">
      <div class="container">
        <div class="article-header">
          {breadcrumbs.length > 0 && (
            <nav class="breadcrumb" aria-label="Breadcrumb">
              <ol>
                <li><a href={url('/')}>Home</a></li>
                {breadcrumbs.map((item, i) => (
                  <li>
                    {i === breadcrumbs.length - 1 ? (
                      <span aria-current="page">{item.name}</span>
                    ) : (
                      <a href={url(item.url)}>{item.name}</a>
                    )}
                  </li>
                ))}
              </ol>
            </nav>
          )}
          {category && (
            <span class="article-category">{category}</span>
          )}
          <h1>{title}</h1>
          <p class="article-description">{description}</p>
          {lastUpdated && (
            <p class="article-meta">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              Last updated: {lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
          )}
        </div>
        
        <div class="article-content">
          <slot />
        </div>
        
        {related && related.length > 0 && (
          <div class="article-related">
            <h2>Related Articles</h2>
            <div class="related-grid">
              {related.map(slug => (
                <a href={url(`/evergreen/${slug}`)} class="related-card">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14 2 14 8 20 8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10 9 9 9 8 9"/>
                  </svg>
                  <span>{slug.replace(/-/g, ' ').replace(/^edu-/, '').replace(/^svc-/, '')}</span>
                </a>
              ))}
            </div>
          </div>
        )}
        
        <div class="article-cta">
          <h2>Ready to Find Your Funding?</h2>
          <p>Get matched with the right financing for your next deal. Free consultation, no obligation.</p>
          <Button href="/contact" size="lg">Get Your Free Consultation</Button>
        </div>
      </div>
    </article>
  </main>
  
  <Footer />
</BaseLayout>

<style>
  .article {
    padding: 3rem 0 5rem;
    background: #FFFFFF;
  }
  
  .breadcrumb {
    margin-bottom: 1.5rem;
  }
  
  .breadcrumb ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.875rem;
  }
  
  .breadcrumb li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  
  .breadcrumb li:not(:last-child)::after {
    content: '/';
    color: var(--text-muted);
  }
  
  .breadcrumb a {
    color: var(--text-secondary);
    text-decoration: none;
  }
  
  .breadcrumb a:hover {
    color: var(--color-secondary);
  }
  
  .breadcrumb span {
    color: var(--text-primary);
    font-weight: 500;
  }
  
  .article-header {
    max-width: 800px;
    margin: 0 auto 3rem;
    text-align: center;
    padding-top: 2rem;
  }
  
  .article-category {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-secondary);
    color: var(--color-primary);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  
  .article-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }
  
  @media (min-width: 768px) {
    .article-header h1 {
      font-size: 3rem;
    }
  }
  
  .article-description {
    font-size: 1.25rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  
  .article-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--text-tertiary);
    margin: 0;
  }
  
  .article-meta svg {
    color: var(--text-muted);
  }
  
  .article-content {
    max-width: 800px;
    margin: 0 auto;
  }
  
  .article-content :global(h2) {
    font-size: 1.75rem;
    color: var(--color-primary);
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light);
  }
  
  .article-content :global(h2:first-of-type) {
    margin-top: 0;
    padding-top: 0;
    border-top: none;
  }
  
  .article-content :global(h3) {
    font-size: 1.375rem;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  
  .article-content :global(h4) {
    font-size: 1.125rem;
    color: var(--color-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .article-content :global(p) {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
  }
  
  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  .article-content :global(li) {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }
  
  .article-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 2rem 0;
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(27, 54, 93, 0.08);
  }
  
  .article-content :global(th) {
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    text-align: left;
    padding: 1rem;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .article-content :global(td) {
    padding: 1rem;
    border-bottom: 1px solid var(--border-light);
    font-size: 0.9375rem;
  }
  
  .article-content :global(tr:last-child td) {
    border-bottom: none;
  }
  
  .article-content :global(tr:hover td) {
    background: var(--bg-tertiary);
  }
  
  .article-content :global(blockquote) {
    border-left: 4px solid var(--color-secondary);
    padding: 1rem 1.5rem;
    margin: 2rem 0;
    background: var(--bg-tertiary);
    border-radius: 0 8px 8px 0;
  }
  
  .article-content :global(blockquote p) {
    margin: 0;
    font-style: italic;
    color: var(--text-secondary);
  }
  
  .article-content :global(a) {
    color: var(--color-secondary);
    text-decoration: underline;
  }
  
  .article-content :global(a:hover) {
    color: var(--color-secondary-dark);
  }
  
  .article-content :global(strong) {
    font-weight: 600;
    color: var(--color-primary);
  }
  
  .article-related {
    max-width: 800px;
    margin: 4rem auto 0;
    padding-top: 2rem;
    border-top: 1px solid var(--border-light);
  }
  
  .article-related h2 {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }
  
  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }
  
  .related-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: var(--bg-tertiary);
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-primary);
    font-weight: 500;
    transition: all 0.2s ease;
  }
  
  .related-card:hover {
    background: var(--color-primary);
    color: white;
  }
  
  .related-card svg {
    flex-shrink: 0;
    color: var(--color-secondary);
  }
  
  .related-card:hover svg {
    color: var(--color-secondary);
  }
  
  .article-cta {
    max-width: 800px;
    margin: 4rem auto 0;
    padding: 3rem;
    background: linear-gradient(180deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    border-radius: 12px;
    text-align: center;
  }
  
  .article-cta h2 {
    color: white;
    font-size: 1.75rem;
    margin-bottom: 0.75rem;
  }
  
  .article-cta p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }
</style>
